# Environment / stage-prod
# STAGE=ON  -> beta.twaps.ru + stage host ports + STAGE_* credentials/settings
# STAGE=OFF -> twaps.ru + prod host ports + PROD_* credentials/settings
# Важно: для Docker запускай через run.bat/run.sh или python tools/compose.py,
# чтобы из STAGE автоматически сгенерировались LOCAL_UI_PORT/SIGNAL_SERVER_PORT/etc.
STAGE=OFF
PROD_DOMAIN=twaps.ru
STAGE_DOMAIN=beta.twaps.ru
PUBLIC_PROTOCOL=https

# Prod host ports
PROD_LOCAL_UI_PORT=8080
PROD_SIGNAL_SERVER_PORT=8090
PROD_PHPMYADMIN_PORT=8081
PROD_MYSQL_HOST_PORT=3306

# Stage host ports
STAGE_LOCAL_UI_PORT=18080
STAGE_SIGNAL_SERVER_PORT=18090
STAGE_PHPMYADMIN_PORT=18081
STAGE_MYSQL_HOST_PORT=13306

# Telegram user app. Значения брать в https://my.telegram.org/apps
# Активный набор выбирается по STAGE.
PROD_TELEGRAM_API_ID=
PROD_TELEGRAM_API_HASH=
PROD_TELEGRAM_PHONE=

STAGE_TELEGRAM_API_ID=
STAGE_TELEGRAM_API_HASH=
STAGE_TELEGRAM_PHONE=

# Общий fallback, если не хочешь разделять Telegram App/номер.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=

# По умолчанию session path общий. Если нужны разные session-файлы, заполни PROD_/STAGE_ варианты.
TELEGRAM_SESSION_PATH=sessions/twap_user.session
PROD_TELEGRAM_SESSION_PATH=
STAGE_TELEGRAM_SESSION_PATH=

# MySQL внутри Docker-сети. MYSQL_HOST_PORT генерируется из STAGE_* / PROD_*.
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=twap_parser
MYSQL_USER=twap_user
MYSQL_PASSWORD=twap_password
MYSQL_ROOT_PASSWORD=root_password

# phpMyAdmin
# Публичный host-port генерируется из STAGE_* / PROD_* как PHPMYADMIN_PORT.

# Группы парсинга. Для новой группы добавляется имя через запятую и свой модуль в app/groups/<name>/
GROUPS=twapx

# TWAPx source/destination
# Активный набор выбирается по STAGE.
# Новый формат source: chat_id[:thread_id],chat_id[:thread_id]
# Если thread/topic нет, указывается только chat_id без двоеточия.
# Пример: -1003918218733:2,-1003918218734:3,-1003918218735,-1003918218736,-1003918218737:1
PROD_TWAPX_SOURCES=-1003663170785
PROD_TWAPX_TARGET=-1003918218733:4
PROD_TWAPX_ENABLED=true

STAGE_TWAPX_SOURCES=-1003663170785,-1003918218733:2
STAGE_TWAPX_TARGET=-1003918218733:4
STAGE_TWAPX_ENABLED=true

# Общий fallback, если не хочешь разделять TWAPx настройки.
TWAPX_SOURCES=
TWAPX_TARGET=
TWAPX_ENABLED=true

# Backward compatibility only. Новые настройки выше предпочтительнее.
TWAPX_SOURCE_CHAT_IDS=
TWAPX_SOURCE_THREAD_IDS=
TWAPX_SOURCE_CHAT_THREADS=
TWAPX_TARGET_CHAT_ID=
TWAPX_TARGET_THREAD_ID=

# Default filter: $300K+ / ≤30 minutes / market volume <$100M / TWAP share >0.5%
TWAPX_MIN_USD=300000
TWAPX_MAX_DURATION_MINUTES=30
TWAPX_MAX_MARKET_VOLUME_USD=100000000
TWAPX_MIN_TWAP_SHARE_PERCENT=0.5

# Debug reports. Отчеты по обработке сообщений: accepted/rejected/error.
DEBUG_ENABLED=true
DEBUG_CHAT_ID=-1003918218733
DEBUG_THREAD_ID=48
# true = отправлять debug и для skipped/unsupported сообщений. По умолчанию лучше false, чтобы не шуметь.
DEBUG_SEND_SKIPPED=false

# History import
HISTORY_LIMIT=1000

# Local compiled client
# Публичный host-port генерируется из STAGE_* / PROD_* как LOCAL_UI_PORT.
LOCAL_SETTINGS_PATH=local_data/settings.json
LOCAL_SIGNALS_PATH=local_data/signals.json
LOCAL_TRADES_PATH=local_data/trades.json

# Local Signal Client. Сигналы слушаются всегда. Адреса и ключ берутся только из .env.
# In docker-compose use service name, not 127.0.0.1.
LOCAL_SIGNAL_WS_URL=ws://signal-server:8090/ws/signals
LOCAL_SIGNAL_HTTP_URL=http://signal-server:8090
# Должен совпадать с SIGNAL_SERVER_ACCESS_KEY, если сервер открыт наружу. В UI не показывается.
LOCAL_SIGNAL_ACCESS_KEY=

# Central Signal Server
# Публичный host-port генерируется из STAGE_* / PROD_* как SIGNAL_SERVER_PORT.
# Если server доступен не только внутри Docker-сети, обязательно задай ключ и скопируй его в LOCAL_SIGNAL_ACCESS_KEY.
SIGNAL_SERVER_ACCESS_KEY=
SIGNAL_SERVER_DB_CHECK_SECONDS=0.5
SIGNAL_SERVER_MAX_WS_CLIENTS=120
SIGNAL_SERVER_HTTP_MAX_PER_MINUTE=300
SIGNAL_SERVER_HEALTH_MIN_INTERVAL_SECONDS=2
SIGNAL_SERVER_PENDING_MIN_INTERVAL_SECONDS=5
SIGNAL_SERVER_WS_MIN_CONNECT_INTERVAL_SECONDS=1
